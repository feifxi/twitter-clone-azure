# ── Environment ──────────────────────────────────────
ENVIRONMENT=development
HTTP_SERVER_ADDRESS=0.0.0.0:8080

# ── Database (PostgreSQL) ────────────────────────────
DATABASE_URL=postgresql://username:password@localhost:5432/twitter_db?sslmode=disable

# DB connection pool tuning.
# Keep DB_MIN_CONNS low for cloud environments to avoid idle connection pressure.
DB_MAX_CONNS=25
DB_MIN_CONNS=0
# Recycle connections periodically to reduce stale connection issues.
DB_MAX_CONN_LIFETIME_MINUTES=5

# ── Authentication & Security ────────────────────────
# Secret key for JWT token signing. 
# MUST be 32+ characters long for HMAC-SHA256 stability.
# Generate one: openssl rand -base64 32
TOKEN_SYMMETRIC_KEY=replace-with-a-strong-32-plus-char-secret

TOKEN_DURATION_MINUTES=15
REFRESH_TOKEN_DURATION_DAYS=30

# Google OAuth Web client ID for social login
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ── Frontend & Cookies ───────────────────────────────
# Comma-separated list of allowed frontend origins (CORS)
FRONTEND_URL=http://localhost:3000

# Cookie settings. Leave domain empty for localhost.
# In production, set to your top-level domain (e.g. .example.com).
COOKIE_DOMAIN=
COOKIE_SAME_SITE=Lax
COOKIE_SECURE=false

# ── Media & AWS Storage ───────────────────────────────
# Upload limits in bytes (Default: 100MB media, 5MB avatar, 10MB banner)
MAX_MEDIA_BYTES=104857600
MAX_AVATAR_BYTES=5242880
MAX_BANNER_BYTES=104857600

# AWS S3 bucket name for uploads
S3_BUCKET_NAME=chmtwt-media-s3
S3_REGION=ap-southeast-1

# CloudFront domain for serving media over HTTPS (without https://)
CLOUDFRONT_DOMAIN=

# ── Infrastructure Guards ────────────────────────────
# Secret header checked with X-Gateway-Secret middleware.
# Leave empty for local development to bypass the gateway guard.
GATEWAY_SECRET=

# ── Caching & Real-time (Redis) ──────────────────────
# Leave REDIS_ADDRESS empty to run with in-memory fallbacks (Websockets/SSE).
REDIS_ADDRESS=redis://localhost:6379
REDIS_PASSWORD=

# ── Assistant & AI (Gemini + RAG) ────────────────────
# Get your API key from https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here
# URL of the SQS queue for tweet embedding events (prod only)
SQS_EMBEDDING_QUEUE_URL=
# Enable/Disable RAG (Timeline Context) toggle
ENABLE_RAG=true
