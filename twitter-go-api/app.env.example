ENVIRONMENT=development
HTTP_SERVER_ADDRESS=0.0.0.0:8080

DATABASE_URL=postgresql://username:password@localhost:5432/twitter_db?sslmode=disable
# DB connection pool tuning.
# Keep DB_MIN_CONNS low for cloud environments to avoid idle connection pressure.
DB_MAX_CONNS=25
DB_MIN_CONNS=0
# Recycle connections periodically to reduce stale connection issues.
DB_MAX_CONN_LIFETIME_MINUTES=5



# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:3000

# Leave empty for localhost; set your domain in production (e.g. .example.com)
COOKIE_DOMAIN=
COOKIE_SAME_SITE=Lax
COOKIE_SECURE=false

# 32+ chars minimum
TOKEN_SYMMETRIC_KEY=replace-with-a-strong-32-plus-char-secret
TOKEN_DURATION_MINUTES=15
REFRESH_TOKEN_DURATION_DAYS=30

# Google OAuth Web client ID
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# AWS S3 (for presigned URL media uploads)
S3_BUCKET_NAME=chmtwt-media-s3
S3_REGION=ap-southeast-1

# CloudFront domain for serving media (e.g. d1234567890.cloudfront.net)
CLOUDFRONT_DOMAIN=

# API Gateway secret (leave empty for local dev — no gateway guard)
GATEWAY_SECRET=

# Redis (leave empty to run without Redis; SSE/rate-limiting will use in-memory fallback)
REDIS_ADDRESS=redis://localhost:6379
REDIS_PASSWORD=
