# ── Project Configuration ────────────────────────────
project_name = "chmtwt"
aws_region   = "ap-southeast-1"

# ── Database (RDS) ──────────────────────────────────
# The password for the PostgreSQL master user
db_name     = "twitter_db"
db_username = "postgres"
db_password = "CHANGE_ME_TO_A_STRONG_PASSWORD"

# ── Secrets & Security ───────────────────────────────
# API Gateway → EC2 secret header (prevents direct public access to EC2)
gateway_secret = "CHANGE_ME_TO_A_RANDOM_SECRET"

# Secret key for JWT token signing (Must be 32+ characters)
# Generate one: openssl rand -base64 32
token_symmetric_key = "CHANGE_ME_TO_A_STRONG_32_PLUS_CHAR_SECRET"

# Google OAuth Web client ID for social login
google_client_id = "YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com"

# Google Gemini API Key for RAG features
gemini_api_key = "YOUR_GEMINI_API_KEY"

# AI Model Configuration
gemini_chat_model      = "gemini-2.5-flash"
gemini_embedding_model = "gemini-embedding-2-preview"

# Enable/Disable RAG (Timeline Context)
enable_rag = true

# ── Frontend & CORS ──────────────────────────────────
# Local frontend URL for development (e.g. http://localhost:3000)
# This allows your local browser to upload directly to S3.
# Leave empty ("") to disable local access in production.
frontend_url = "http://localhost:3000"

# ── CI/CD (GitHub & Amplify) ──────────────────────────
gh_repo_url = "https://github.com/feifxi/twitter-aws"
gh_branch   = "main"

# GitHub Personal Access Token (Classic). 
# Req: 'repo' and 'admin:repo_hook' permissions.
gh_token = "YOUR_GITHUB_PERSONAL_ACCESS_TOKEN"

# ── Optional Overrides (Defaults are in variables.tf) ──
# db_max_conns = "25"
# max_media_bytes = "104857600"
# max_banner_bytes = "104857600"
# redis_address = ""

# ── Grafana Cloud Monitoring (Optional) ───────────────
# Get these values from your Grafana Cloud portal
# grafana_cloud_prometheus_url  = "https://prometheus-prod-01-...-remote-write"
# grafana_cloud_prometheus_user = "12345"
# grafana_cloud_loki_url        = "https://logs-prod-01-...-loki.grafana.net/loki/api/v1/push"
# grafana_cloud_loki_user       = "67890"
# grafana_cloud_api_token       = "glc_..."
